<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- Header / Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gestión de Horarios de Atención"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card de Agregar Horario -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➕ Agregar Nuevo Horario"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <!-- Spinner de Hospitales -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hospital / Centro Médico:"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spHospitals"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_card_outlined"
                        android:padding="8dp" />

                    <!-- Fila de Selección de Fecha y Hora -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Fecha -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <Button
                                android:id="@+id/btnPickDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Elegir Fecha"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvSelectedDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sin seleccionar"
                                android:gravity="center"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Hora -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="6dp">

                            <Button
                                android:id="@+id/btnPickTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Elegir Hora"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvSelectedTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sin seleccionar"
                                android:gravity="center"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnAddSlot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Agregar Horario a Disponibilidad"
                        android:backgroundTint="@color/primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Lista de Horarios Registrados -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Mis Horarios Programados"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvNoSchedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No tienes horarios de atención registrados."
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:padding="24dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMySchedules"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:nestedScrollingEnabled="false" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Volver al Panel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
