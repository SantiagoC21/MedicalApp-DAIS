<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MedApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize light theme here -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- CardView properties override -->
        <item name="cardBackgroundColor">@color/bg_card</item>
    </style>

    <style name="Theme.MedApp" parent="Base.Theme.MedApp" />
</resources>