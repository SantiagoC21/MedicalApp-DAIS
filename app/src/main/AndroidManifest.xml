<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.hospital.medapp">

    <!-- ─── Permisos ─────────────────────────────────────────────────────────── -->
    <!-- Cámara: para sensor PPG (fotopletismografía) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Flash: para iluminar el dedo durante la medición PPG -->
    <uses-feature android:name="android.hardware.camera.flash" android:required="true" />
    <!-- Sensor de frecuencia cardíaca (en dispositivos con sensor dedicado) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <!-- Internet: para sincronización futura con backend / notificaciones -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Almacenamiento: para guardar/leer documentos de médicos -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_DOCUMENTS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MedApp">

        <!-- ─── Actividades ──────────────────────────────────────────────────── -->

        <!-- Punto de entrada: Login -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Registro de usuario (paciente o médico) -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Dashboard del paciente -->
        <activity
            android:name=".activities.PatientDashboardActivity"
            android:exported="false" />

        <!-- Dashboard del médico -->
        <activity
            android:name=".activities.DoctorDashboardActivity"
            android:exported="false" />

        <!-- Lista de hospitales para elegir cita -->
        <activity
            android:name=".activities.HospitalListActivity"
            android:exported="false" />

        <!-- Selección de horario y reserva de cita -->
        <activity
            android:name=".activities.AppointmentActivity"
            android:exported="false" />

        <!-- Triaje con sensor PPG -->
        <activity
            android:name=".activities.TriageActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Gestión de horarios del médico -->
        <activity
            android:name=".activities.ManageScheduleActivity"
            android:exported="false" />

    </application>

</manifest>
